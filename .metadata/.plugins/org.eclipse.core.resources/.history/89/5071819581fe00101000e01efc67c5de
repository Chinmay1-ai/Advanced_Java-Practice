package com.task;

public class Task_3 {

	public static void main(String[] args) {

		String pass = "ChinmayPawar";

		StringBuilder consonent = new StringBuilder(pass);
		StringBuilder vowels = new StringBuilder(pass);

		for (int i = 0; i < pass.length(); i++) {

			char c = pass.charAt(i);
			if (c(i) == 'A' ||c(i) == 'E' ||c(i) == 'A' ||c(i) == 'A' ||c(i) == 'A' ||) {
				consonent.append(c);
			} else {
				vowels.append(c);
			}
		}
		System.out.println("Consonent are = " + consonent);
		System.out.println("Vowels are = " + vowels);
	}
}